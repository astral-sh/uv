{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "reproduction": {
      "type": "string",
      "enum": ["reproducible", "not_reproducible", "needs_more_information"]
    },
    "reason": { "type": "string" },
    "dockerfile": {
      "type": ["string", "null"],
      "description": "A minimal, self-contained Dockerfile for a reproducible Linux-specific bug, or null when not applicable."
    }
  },
  "required": ["reproduction", "reason", "dockerfile"]
}
