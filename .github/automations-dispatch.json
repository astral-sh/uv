{
  "version": 2,
  "repositories": {
    "uv-dev": {
      "name": "astral-sh/uv-dev",
      "id": 1302176231
    }
  },
  "rules": [
    {
      "repository": "uv-dev",
      "on": {
        "pull_request": ["ready_for_review"]
      },
      "workflow": "promote-pull-request.yml"
    },
    {
      "repository": "uv-dev",
      "on": {
        "ost_dispatch_canary": ["created"]
      },
      "workflow": "issue-triage.yml",
      "inputs": {
        "issue": "/canary/issue"
      }
    }
  ]
}
